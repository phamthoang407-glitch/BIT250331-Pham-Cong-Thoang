def count_vowels(s):
    vowels = "aeiouAEIOU" 
    count = 0
    for char in s:
        if char in vowels:
            count += 1
    return count
text = input("Nhập một chuỗi: ")
print("Số lượng nguyên âm là:", count_vowels(text))
