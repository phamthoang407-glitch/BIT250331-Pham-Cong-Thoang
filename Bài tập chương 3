###  bài tập 6
def bubble_sort(arr):
    n = len(arr)
    swap_count = 0
    for i in range(n - 1):
        for j in range(n - 1 - i):
            if arr[j] > arr[j + 1]:
                arr[j], arr[j + 1] = arr[j + 1], arr[j]
                swap_count += 1
    return arr, swap_count
numbers = input("Nhập danh sách số nguyên: ")
arr = [int(x) for x in numbers.split()]
sorted_arr, swaps = bubble_sort(arr)
print("Danh sách sau khi sắp xếp tăng dần:", sorted_arr)
print("Số lần hoán đổi:", swaps)
